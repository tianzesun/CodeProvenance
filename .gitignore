###############
node_modules/
.next/
.turbo/
dist/
build/
.cache/
pnpm-debug.log

###############
# Infrastructure (Keep these!)
###############
.docker/
postgres_data/
redis_data/

###############
# OS & IDE
###############
.DS_Store
.vscode/
.idea/
*.swp
*.swo

###############
# Testing & Coverage
###############
coverage/
test-results/
.pytest_cache/
