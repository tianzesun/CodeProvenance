###############
# Python Virtual Environments
###############
venv/
env/
ENV/
.venv/
.env/

# Python bytecode
*.pyc
*.pyo
*.pyd
*.pycache/

###############
# Windows Zone.Identifier Files
###############
*.Zone.Identifier
:Zone.Identifier*

###############
# Logs
###############
log/
*.log

###############
# Data Directory (immutable datasets - too large for git)
###############
data/*

# Keep only dataset scripts, metadata and documentation
!data/datasets/*.sh
!data/datasets/*.md
!data/datasets/*.json
!data/datasets/*.lock

###############
# Uploads (user-submitted files - not tracked)
###############
uploads/

###############
# Artifacts (reproducible outputs - deletable)
###############
artifacts/

###############
# Reports (disposable generated outputs)
###############
reports/

###############
# Experiments (research runs - deletable)
###############
experiments/runs/

###############
# Backend runtime workspaces
###############
apps/backend/data/
apps/backend/uploads/
*.tsbuildinfo
apps/frontend/tsconfig.tsbuildinfo
test_results/

###############
# Model Caches
###############
.unixcoder_cache/
.embedding_cache/

###############
# IDE & Editor Caches
###############
.mypy_cache/
.ruff_cache/
.pyright/

# Temporary tools and databases
tools/*

# Keep tool scripts, configs and documentation
!tools/*.sh
!tools/*.py
!tools/*.md
!tools/__init__.py
!tools/.gitkeep
!tools/configs/
!tools/registry/

# Ignore actual downloaded tool binaries
tools/JPlag/
tools/pmd/
tools/sim/
tools/dolos-cli/
tools/NiCad-6.2/
tools/sherlock/
tools/libs/
tools/outputs/
tools/external/
tools/sandbox/
*.db
*.db.*
.codex/
tsunn*
sandbox/
outputs/
